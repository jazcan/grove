{
  "name": "grove",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "clean": "rm -rf .next",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "npm test && npm run lint && npm run build && npm run uat:env",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:apply-sql": "tsx scripts/apply-sql-migration.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/seed.ts",
    "worker": "tsx src/worker/index.ts",
    "audit": "npm audit --audit-level=high",
    "uat:env": "tsx scripts/uat-env-check.ts",
    "uat:e2e": "PLAYWRIGHT_BROWSERS_PATH=.playwright-browsers playwright test e2e/uat-auth.spec.ts e2e/uat-public-routes.spec.ts",
    "uat:e2e:full": "PLAYWRIGHT_BROWSERS_PATH=.playwright-browsers playwright test",
    "playwright:install": "PLAYWRIGHT_BROWSERS_PATH=.playwright-browsers playwright install chromium"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.750.0",
    "@aws-sdk/s3-request-presigner": "^3.750.0",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/react": "^6.1.20",
    "@fullcalendar/timegrid": "^6.1.20",
    "@shopify/app-bridge": "^3.7.11",
    "@shopify/shopify-api": "^13.0.0",
    "argon2": "^0.41.1",
    "bullmq": "^5.34.8",
    "drizzle-orm": "^0.39.3",
    "ioredis": "^5.4.2",
    "luxon": "^3.5.0",
    "next": "^15.2.0",
    "postgres": "^3.4.5",
    "react": "^19.0.0",
    "react-big-calendar": "^1.19.4",
    "react-dom": "^19.0.0",
    "resend": "^4.1.2",
    "uuid": "^11.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@playwright/test": "^1.51.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/luxon": "^3.4.2",
    "@types/node": "^22.13.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "^0.30.4",
    "eslint": "^9.19.0",
    "eslint-config-next": "^15.2.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
