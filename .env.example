# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/grove

# Session secret (32+ random bytes, base64 or hex)
SESSION_SECRET=change-me-to-a-long-random-string

# CSRF secret
CSRF_SECRET=change-me-csrf-secret

# App URL (no trailing slash)
APP_URL=http://localhost:3000

# Redis for BullMQ (optional for dev — if unset, notification jobs are skipped).
# If set, Redis must be running (e.g. docker run -p 6379:6379 redis:7-alpine) or you will see connection errors after bookings.
REDIS_URL=redis://localhost:6379

# Email (Resend) — optional; logs only if unset
RESEND_API_KEY=
EMAIL_FROM=noreply@example.com

# S3-compatible storage for profile images
# — In development, if these are unset, profile photos save under public/uploads/profiles (gitignored).
# — In production, set all of S3_ENDPOINT, S3_BUCKET, S3_ACCESS_KEY_ID, S3_SECRET_ACCESS_KEY.
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Public base URL for stored keys (CDN or bucket URL). Optional; defaults to endpoint/bucket.
S3_PUBLIC_BASE_URL=

# Comma-separated admin user emails (Stage 6)
ADMIN_EMAILS=

# Feature flags (optional overrides)
FEATURE_AI_GATEWAY=false

# OpenAI — optional; AI copy for Dashboard → Marketing → “Reconnect” drafts only (other sections use local samples until wired)
OPENAI_API_KEY=
# Default if unset: gpt-4o-mini
MARKETING_OPENAI_MODEL=
# Set to false to force offline sample drafts even when OPENAI_API_KEY is set
MARKETING_AI_RECONNECT=

# Provider assistant (optional) — deterministic rules are default; OpenAI only softens Ask replies when enabled
# ASSISTANT_OPENAI_REPHRASE=true
# ASSISTANT_OPENAI_MODEL=gpt-4o-mini

# Shopify embedded app (optional)
# Install URL (after deploy): {APP_URL}/api/shopify/oauth?shop=YOUR_STORE.myshopify.com
# App URL in Partner Dashboard: {APP_URL}/shopify
# Redirect / callback: {APP_URL}/api/shopify/oauth/callback
# Webhooks: {APP_URL}/api/shopify/webhooks  (topic: app/uninstalled)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
# Comma-separated OAuth scopes (default read_products if unset)
SHOPIFY_SCOPES=read_products
